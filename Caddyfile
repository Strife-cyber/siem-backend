# Smart SIEM CTU — Caddy Configuration

http://localhost, http://strife-cyber.taild0a5b5.ts.net {
    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
        -Server
    }

    # Compress
    encode gzip

    # ── Static assets: serve from disk if exists, fallback to SSR if not ──
    handle /assets/* {
        root * /var/www/frontend
        # Only serve file_server if the file actually exists on disk
        @asset_file file {
            try_files {path}
        }
        handle @asset_file {
            file_server
            header Cache-Control "public, max-age=31536000, immutable"
        }
        # File not found → proxy to frontend SSR (handles hash mismatches)
        handle {
            reverse_proxy frontend:3001
        }
    }

    # ── API backend ──
    handle /api/* {
        reverse_proxy app:3000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ── WebSocket ──
    handle /ws/* {
        reverse_proxy app:3000
    }

    # ── Frontend SSR (routes only, assets handled above) ──
    handle {
        reverse_proxy frontend:3001
    }
}
