<!DOCTYPE html>
<html>
<head><meta charset="utf-8"></head>
<body style="font-family: Arial, sans-serif; background: #f4f4f4; padding: 32px;">
<div style="max-width: 600px; margin: auto; background: white; border-radius: 8px; padding: 32px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <div style="border-left: 4px solid {{color}}; padding-left: 16px; margin-bottom: 24px;">
    <h2 style="color: {{color}}; margin: 0;">[{{severity}}] {{rule_name}}</h2>
    <p style="color: #475569; margin-top: 8px;">{{summary}}</p>
  </div>

  <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
    <tr><td style="padding: 8px; color: #64748b;">Rule</td><td style="padding: 8px; font-weight: bold;">{{rule_id}} — {{rule_name}}</td></tr>
    <tr style="background: #f8fafc;"><td style="padding: 8px; color: #64748b;">Confidence</td><td style="padding: 8px; font-weight: bold;">{{confidence_score}}/100</td></tr>
    <tr><td style="padding: 8px; color: #64748b;">Time</td><td style="padding: 8px; font-weight: bold;">{{triggered_at}}</td></tr>
    {{#if ips}}<tr style="background: #f8fafc;"><td style="padding: 8px; color: #64748b;">IPs</td><td style="padding: 8px; font-weight: bold; font-family: monospace;">{{join ips ", "}}</td></tr>{{/if}}
    {{#if hosts}}<tr><td style="padding: 8px; color: #64748b;">Hosts</td><td style="padding: 8px; font-weight: bold;">{{join hosts ", "}}</td></tr>{{/if}}
    {{#if users}}<tr style="background: #f8fafc;"><td style="padding: 8px; color: #64748b;">Users</td><td style="padding: 8px; font-weight: bold;">{{join users ", "}}</td></tr>{{/if}}
  </table>

  <a href="{{dashboard_url}}/incidents/{{id}}" style="display: inline-block; margin-top: 24px; background: {{color}}; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold;">View in SIEM</a>

  <hr style="border: none; border-top: 1px solid #e2e8f0; margin: 24px 0;">
  <p style="color: #94a3b8; font-size: 12px;">Smart SIEM CTU — Automated Incident Alert</p>
</div>
</body>
</html>
